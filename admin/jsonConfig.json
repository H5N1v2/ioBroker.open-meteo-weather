            { "value": 3, "label": "days_3" },
            { "value": 6, "label": "days_6" }
          ],
          "xs": 12, "sm": 6, "md": 4, "lg": 3, "xl": 3,
          "hidden": "!data.airQualityEnabled"
        },
                  "divider4": { "type": "divider", "xs": 12, "sm": 12, "md": 12, "lg": 12, "xl": 12 }
      }
